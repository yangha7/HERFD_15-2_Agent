# ── LLM Provider Configuration ──────────────────────────────────────────────
# The agent auto-detects the provider from whichever API key is set.
# Or set LLM_PROVIDER explicitly to choose one.
#
# Option 1: CBORG (LBL users) — default if CBORG_API_KEY is set
# CBORG_API_KEY=your-cborg-api-key-here

# Option 2: OpenAI
# OPENAI_API_KEY=your-openai-api-key-here

# Option 3: Google Gemini
# GEMINI_API_KEY=your-gemini-api-key-here

# Option 4: Anthropic Claude (direct)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Optional overrides ──────────────────────────────────────────────────────
# LLM_PROVIDER=cborg          # Force a specific provider (cborg/openai/gemini/claude)
# LLM_MODEL=gpt-4o            # Override the default model for the chosen provider
# LLM_BASE_URL=https://...    # Override the API base URL

# ── Data directories ────────────────────────────────────────────────────────
# HERFD_DATA_DIR=2026-05_Yano       # Root directory for HERFD data
# HERFD_EXPORT_DIR=exported_data    # Directory for exported results
